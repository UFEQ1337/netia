# Konfiguracja środowiska testowego. Skopiuj do `.env` i dostosuj w razie potrzeby.
# Wszystkie wartości mają sensowne domyślne (zgodne z docker-compose), więc plik .env jest opcjonalny.

# Backend REST API (adres bazowy z prefiksem wersji)
API_URL=http://localhost:8080/api/v1

# Frontend (React SPA)
FRONTEND_URL=http://localhost:3000

# Keycloak (serwer autoryzacji)
KC_URL=http://localhost:8180
KC_REALM=ttapi
KC_CLIENT_ID=ttapi-client

# Wspólne hasło użytkowników testowych (alpha/beta/gamma)
TT_PASSWORD=Test1234!
